class Solution {
    public int[] getConcatenation(int[] nums) {
        int n=nums.length;
        int i;
        int[] ans = new int[2 * n];
        for(i=0;i<n;i++)
        {
         ans[i]=nums[i];
        }
        while(i<2*n)
        {
            ans[i]=nums[i-n];
            i++;

        } 
        return ans;
    }
}